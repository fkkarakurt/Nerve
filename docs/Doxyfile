# Doxyfile — Nerve Neural Network Library
# Generate: doxygen docs/Doxyfile
# Output:   docs/doxygen/html/index.html   (browser)
#           docs/doxygen/latex/refman.pdf (pdflatex docs/doxygen/latex/Makefile)  (pdflatex docs/output/latex/Makefile)

# ---------------------------------------------------------------------------
# Project identity
# ---------------------------------------------------------------------------
PROJECT_NAME           = "Nerve"
PROJECT_NUMBER         = 2.0.0
PROJECT_BRIEF          = "Zero-dependency multilayer perceptron in ANSI C"
OUTPUT_DIRECTORY       = docs/doxygen

# ---------------------------------------------------------------------------
# Input sources
# ---------------------------------------------------------------------------
INPUT                  = nerve.h \
                         README.md \
                         docs/mathematics.dox
FILE_PATTERNS          = *.h *.dox *.md
RECURSIVE              = NO
USE_MDFILE_AS_MAINPAGE = README.md
EXCLUDE_PATTERNS       = */build/* */.git/*

# ---------------------------------------------------------------------------
# Extraction settings
# ---------------------------------------------------------------------------
EXTRACT_ALL            = YES
EXTRACT_STATIC         = YES
EXTRACT_PRIVATE        = NO
JAVADOC_AUTOBRIEF      = YES
OPTIMIZE_OUTPUT_FOR_C  = YES
TYPEDEF_HIDES_STRUCT   = YES

# Ensure the implementation block is parsed
PREDEFINED             = NERVE_IMPLEMENTATION \
                         __cplusplus

# ---------------------------------------------------------------------------
# HTML output
# ---------------------------------------------------------------------------
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_COLORSTYLE        = LIGHT
HTML_DYNAMIC_SECTIONS  = YES
GENERATE_TREEVIEW      = YES
TREEVIEW_WIDTH         = 250

# ---------------------------------------------------------------------------
# LaTeX output (for PDF generation)
# ---------------------------------------------------------------------------
GENERATE_LATEX         = YES
LATEX_OUTPUT           = latex
COMPACT_LATEX          = YES
PAPER_TYPE             = a4
EXTRA_PACKAGES         = amsmath amssymb

# ---------------------------------------------------------------------------
# Formula rendering (requires latex + dvips or MathJax)
# ---------------------------------------------------------------------------
USE_MATHJAX            = YES
MATHJAX_VERSION        = MathJax_3
FORMULA_FONTSIZE       = 11

# ---------------------------------------------------------------------------
# Diagrams
# ---------------------------------------------------------------------------
HAVE_DOT               = NO
CLASS_DIAGRAMS         = NO

# ---------------------------------------------------------------------------
# Build / output control
# ---------------------------------------------------------------------------
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
GENERATE_TODOLIST      = YES
GENERATE_BUGLIST       = YES
SORT_MEMBER_DOCS       = NO
SHOW_FILES             = YES
SHOW_NAMESPACES        = NO
